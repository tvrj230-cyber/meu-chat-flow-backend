{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "crons": [
    {
      "path": "/api/cron-remarketing",
      "schedule": "0 0 * * *"
    }
  ],
  "routes": [
    {
      "src": "/api/cron-remarketing",
      "dest": "/api/cron-remarketing.js"
    },
    {
      "src": "/api/webhook",
      "dest": "/api/webhook.js"
    },
    {
      "src": "/(.*)",
      "dest": "/api/webhook.js"
    }
  ]
}
